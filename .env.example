VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only — used by the /api/parse-ingredients Vercel function to call
# the Anthropic API. Set this in the Vercel dashboard (Project Settings →
# Environment Variables). Add it to .env locally only if you run `vercel dev`.
ANTHROPIC_API_KEY=your-anthropic-api-key
